---
const photos = [
  { src: '/images/room01.png', alt: '布団が並ぶ客室', label: 'ROOM' },
  { src: '/images/riders01.png', alt: '宿の前に集まったライダーとバイク', label: 'RIDERS' },
  { src: '/images/tento.png', alt: '林の中に張られたオレンジ色のテント', label: 'CAMP' },
  { src: '/images/setubi.png', alt: '館内の設備', label: 'HOUSE' },
  { src: '/images/room05.png', alt: '窓のある客室', label: 'ROOM' },
  { src: '/images/riders03.png', alt: '虎の穴を訪れたライダーたち', label: 'MEMORIES' },
];
---

<section class="gallery" id="gallery" aria-labelledby="gallery-title">
  <div class="gallery__heading container js-reveal">
    <p class="eyebrow"><span class="eyebrow__number">03</span><span class="eyebrow__label">SCENES</span></p>
    <h2 class="section-title" id="gallery-title">ここで過ごす、<br /><span class="section-title__accent">旅のひとコマ。</span></h2>
  </div>
  <div class="gallery__rail-wrap">
    <div class="gallery__rail js-gallery-rail">
      {photos.map((photo) => (
        <figure class="gallery-card">
          <div class="gallery-card__image-wrap"><img class="gallery-card__image" src={photo.src} alt={photo.alt} width="750" height="562" loading="eager" decoding="async" /></div>
          <figcaption class="gallery-card__caption"><span class="gallery-card__label">{photo.label}</span><span class="gallery-card__line"></span></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
