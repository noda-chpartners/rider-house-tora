---
import { Image } from 'astro:assets';
import room01 from '../assets/images/room01.png';
import riders01 from '../assets/images/riders01.png';
import tento from '../assets/images/tento.png';
import setubi from '../assets/images/setubi.png';
import room05 from '../assets/images/room05.png';
import riders03 from '../assets/images/riders03.png';

const photos = [
  { src: room01, alt: '布団が並ぶ客室', label: 'ROOM' },
  { src: riders01, alt: '宿の前に集まったライダーとバイク', label: 'RIDERS' },
  { src: tento, alt: '林の中に張られたオレンジ色のテント', label: 'CAMP' },
  { src: setubi, alt: '館内の設備', label: 'HOUSE' },
  { src: room05, alt: '窓のある客室', label: 'ROOM' },
  { src: riders03, alt: '虎の穴を訪れたライダーたち', label: 'MEMORIES' },
];
---

<section class="gallery" id="gallery" aria-labelledby="gallery-title">
  <div class="gallery__heading container js-reveal">
    <p class="eyebrow"><span class="eyebrow__number">03</span><span class="eyebrow__label">SCENES</span></p>
    <h2 class="section-title" id="gallery-title">ここで過ごす、<br /><span class="section-title__accent">旅のひとコマ。</span></h2>
  </div>
  <div class="gallery__rail-wrap">
    <div class="gallery__rail js-gallery-rail">
      {photos.map((photo) => (
        <figure class="gallery-card">
          <div class="gallery-card__image-wrap">
            <Image
              class="gallery-card__image"
              src={photo.src}
              alt={photo.alt}
              widths={[400, 640, 800]}
              sizes="(max-width: 767px) 78vw, 26vw"
              format="webp"
              quality={78}
              loading="eager"
              decoding="async"
            />
          </div>
          <figcaption class="gallery-card__caption"><span class="gallery-card__label">{photo.label}</span><span class="gallery-card__line"></span></figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
