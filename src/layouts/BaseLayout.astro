---
import '../styles/global.css';
import '../styles/page.scss';

interface Props {
  title: string;
  description: string;
  /** ページ固有のOGP画像（未指定時はデフォルト） */
  image?: string;
  /** true のとき検索エンジンにインデックスさせない */
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/images/ogp.png',
  noindex = false,
} = Astro.props;

const siteName = '佐久ライダーハウス虎の穴';
const siteDescription = description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const ogLocale = 'ja_JP';
const themeColor = '#173d31';

const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
---

<!doctype html>
<html lang="ja" class="site-root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={siteDescription} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="author" content={siteName} />
    <meta name="keywords" content="佐久ライダーハウス虎の穴,ライダーハウス,佐久市,長野県,バイク宿,素泊まり,ドミトリー,キャンプ,宿泊" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content="light" />

    <!-- Geo / Local -->
    <meta name="geo.region" content="JP-20" />
    <meta name="geo.placename" content="長野県佐久市" />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="alternate" hreflang="ja" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:secure_url" content={imageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={`${siteName}の外観とバイク`} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content={`${siteName}の外観とバイク`} />
  </head>
  <body class="site-body">
    <a class="skip-link" href="#main">本文へ移動</a>
    <slot />
  </body>
</html>
